# Production env for the DO droplet deploy. Copy to /opt/poefissure/app.env on the
# droplet (NEVER commit it). docker-compose.prod.yml passes it to both the app and
# the cloudflared sidecar via env_file (literal values — bcrypt hashes with $ are
# safe; there is NO ${} interpolation, which is why this is app.env not .env).
# (scripts/deploy-droplet.sh writes this file for you from your local secrets.)

# Cloudflare Tunnel token for the droplet-sfo tunnel (from blt-infra):
#   terraform -chdir=terraform/cloudflare output -raw droplet_tunnel_token
TUNNEL_TOKEN=

# App login
APP_PASSWORD_HASH=
SESSION_SECRET=

# GGG character + token (read-only). Mint locally: ./poefissure auth login
POE_CHARACTER=Frozenmulligan
POE_LEAGUE=Runes of Aldur
POE_REALM=poe2
POE_CONTACT=you@example.com
GGG_REFRESH_TOKEN=

# Trade pricing (your browser POESESSID; leave blank to disable Upgrades pricing)
POE_SESSID=

# Cloudflare terminates TLS, so the app serves plain HTTP behind the tunnel but
# still sets Secure cookies (the browser sees HTTPS via Cloudflare). Do NOT set
# APP_DEV in production.
