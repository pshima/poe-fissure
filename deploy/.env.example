# Copy to deploy/.env and fill in. NEVER commit deploy/.env (it's gitignored).
# Note: values are used verbatim — do not quote, and bcrypt hashes (with $) are
# fine here because env_file does not perform variable expansion.

# --- public site (Caddy auto-TLS) ---
DOMAIN=poe.example.com          # DNS A record must point at this server
ACME_EMAIL=you@example.com      # for Let's Encrypt expiry notices

# --- app login ---
# Generate the hash:  docker compose -f deploy/docker-compose.yml run --rm app hash 'your-password'
APP_PASSWORD_HASH=
# Generate the secret: docker compose -f deploy/docker-compose.yml run --rm app gen-secret
SESSION_SECRET=

# --- GGG character + token (read-only, your own character) ---
POE_CHARACTER=Frozenmulligan
POE_LEAGUE=Runes of Aldur
POE_REALM=poe2
POE_CONTACT=you@example.com
# Mint once locally with the CLI: `./poefissure auth login`, then copy the
# "refresh_token" value out of ~/.config/poefissure/token.json (macOS:
# ~/Library/Application Support/poefissure/token.json).
GGG_REFRESH_TOKEN=

# --- trade pricing (optional) ---
# Your browser's POESESSID cookie for pathofexile.com. Leave blank to disable the
# Upgrades/price endpoints. Refresh it when it expires (the app reports a clear
# "update POESESSID" error).
POE_SESSID=

# Optional: serve cached snapshot for N minutes before refetching (0 = only on
# explicit Refresh).
# CHAR_MAX_AGE_MIN=0
